# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Secret used to sign login tokens. Use a long random string in production,
# e.g. generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
CIRQLE_SECRET_KEY=change-me-to-a-long-random-string

# Database. Leave DATABASE_URL unset for local dev (uses the SQLite file below).
# In production set DATABASE_URL to the Amazon RDS PostgreSQL connection string:
#   DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@ENDPOINT:5432/DBNAME
# When DATABASE_URL is set, CIRQLE_DB_PATH is ignored.
CIRQLE_DB_PATH=cirqle.db

# Which website origins may call this API. "*" is fine for local dev because we
# authenticate with a bearer token (no cookies). Lock this down in production,
# e.g. CIRQLE_CORS_ORIGINS=https://cirqle.example.com
CIRQLE_CORS_ORIGINS=*

# Apify API token, used server-side to scrape Instagram mentions for the feed.
# Get it from Apify → Settings → Integrations → API tokens. This stays on the
# server and is NEVER sent to the browser.
APIFY_TOKEN=

# Instagram account whose mentions we scrape (posts that tag it). Optional.
CIRQLE_BRAND_HANDLE=cirqle.ltd

# ── Campaigns (Phase 3) ──
# Shared key required to create/edit/delete campaigns (sent as the X-Admin-Key
# header). Use a long random string in production.
CIRQLE_ADMIN_KEY=dev-admin-key

# Campaign image storage. Leave S3_BUCKET unset for local dev — images are then
# saved under backend/media/ and served by the API at /media. In production set
# S3_BUCKET (+ AWS_REGION) and give the server IAM permission to PutObject.
S3_BUCKET=
AWS_REGION=eu-west-2

# Base URL the LOCAL-mode images are reachable at (ignored when S3_BUCKET is set).
# Should point at this API, e.g. http://localhost:8000 locally.
CIRQLE_MEDIA_BASE=http://localhost:8000
